# Yamper environment variables
# Copy this file to software/.env and fill in your API keys.
#
#   cp .env.example software/.env
#   nano software/.env
#

# Set to True to use Hack Club API + Free STT/TTS
USE_FREE_AI=True

# Hack Club API Key (from https://ai.hackclub.com/dashboard)
HACKCLUB_API_KEY=sk-hc-...

# OpenAI API Key (if USE_FREE_AI is False)
OPENAI_API_KEY=sk-your-key-here
